{
    "buildCommand": "tsc -b && vite build",
    "installCommand": "npm install",
    "framework": "vite",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "index, follow"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/proxy",
            "destination": "/api/proxy"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}